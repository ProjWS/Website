---
import Base from '../layouts/Base.astro';
---

<Base
  title="Contatti | Mens Sana Formazione Milano"
  description="Contatta Mens Sana Formazione: Via San Francesco d'Assisi 13, Milano. Tel 02 8155 8505, info@mensanaformazione.com. Preventivi gratuiti per corsi e servizi digitali."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contatti</p>
      <h1>Parliamone</h1>
      <p class="page-hero__sub">
        Un corso, una consulenza o il sito della tua attività: scrivici due
        righe e ti rispondiamo entro un giorno lavorativo.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contatti-grid">
      <!-- FORM -->
      <form
        class="card contatti-form reveal"
        action="https://formsubmit.co/info@mensanaformazione.com"
        method="POST"
      >
        <input type="hidden" name="_subject" value="Nuova richiesta dal sito" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <label>
          Nome e cognome
          <input type="text" name="nome" required autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          Telefono <span class="facolt">(facoltativo)</span>
          <input type="tel" name="telefono" autocomplete="tel" />
        </label>
        <label>
          Mi interessa
          <select name="interesse" required>
            <option value="">Scegli…</option>
            <option>Un corso a catalogo</option>
            <option>Formazione aziendale su misura</option>
            <option>Consulenza (GDPR, contratti, transfer pricing)</option>
            <option>Mens Sana Digital: sito web / menu digitale</option>
            <option>Altro</option>
          </select>
        </label>
        <label>
          Messaggio
          <textarea name="messaggio" rows="5" required placeholder="Raccontaci in due righe di cosa hai bisogno…"></textarea>
        </label>
        <button type="submit" class="btn btn--primary">Invia la richiesta</button>
        <p class="privacy-note">
          Inviando il modulo acconsenti al trattamento dei dati per rispondere
          alla tua richiesta (art. 13 GDPR).
        </p>
      </form>

      <!-- INFO -->
      <div class="contatti-info reveal">
        <div class="info-block">
          <h3>Sede</h3>
          <p>Via San Francesco d'Assisi, 13<br />20122 Milano</p>
          <a
            href="https://maps.google.com/?q=Via+San+Francesco+d'Assisi+13+Milano"
            target="_blank"
            rel="noopener"
            >Apri in Google Maps →</a
          >
        </div>
        <div class="info-block">
          <h3>Telefono</h3>
          <p>
            <a href="tel:+390281558505">(+39) 02 8155 8505</a><br />
            <a href="tel:+393519013820">(+39) 351 901 3820</a>
          </p>
        </div>
        <div class="info-block">
          <h3>Email</h3>
          <p>
            <a href="mailto:info@mensanaformazione.com">info@mensanaformazione.com</a><br />
            PEC: info@pec.mensanaformazione.com
          </p>
        </div>
        <div class="info-block">
          <h3>Orari</h3>
          <p>Lun-Ven: 9:00-18:00<br />Sabato: 9:00-12:00</p>
        </div>
        <div class="info-block info-block--dati">
          <h3>Dati societari</h3>
          <p>Mens Sana Formazione S.r.l.<br />P.IVA 10160940960</p>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-hero {
    background:
      radial-gradient(ellipse 55% 60% at 90% 0%, rgba(200, 32, 47, 0.08), transparent),
      var(--carta);
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }
  .page-hero__sub {
    margin-top: 1.25rem;
    max-width: 38rem;
    font-size: var(--fs-500);
    color: var(--grigio-700);
  }

  .contatti-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    align-items: start;
  }
  @media (max-width: 820px) {
    .contatti-grid { grid-template-columns: 1fr; }
  }

  .contatti-form { display: flex; flex-direction: column; gap: 1.1rem; }
  .contatti-form label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-weight: 600;
    font-size: var(--fs-300);
    color: var(--nero);
  }
  .facolt { font-weight: 400; color: var(--grigio-500); }
  .contatti-form input,
  .contatti-form select,
  .contatti-form textarea {
    font: inherit;
    width: 100%;
    min-width: 0;
    padding: 0.75rem 0.9rem;
    border: 1.5px solid var(--grigio-300);
    border-radius: 10px;
    background: var(--bianco);
    color: var(--nero);
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .contatti-form input:focus,
  .contatti-form select:focus,
  .contatti-form textarea:focus {
    outline: none;
    border-color: var(--rosso);
    box-shadow: 0 0 0 3px rgba(200, 32, 47, 0.15);
  }
  .contatti-form textarea { resize: vertical; }
  .contatti-form .btn { align-self: flex-start; margin-top: 0.4rem; }
  .privacy-note { font-size: var(--fs-200); color: var(--grigio-500); }

  .contatti-info { display: flex; flex-direction: column; gap: 1.75rem; }
  .info-block h3 {
    font-size: var(--fs-300);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--rosso);
    margin-bottom: 0.35rem;
  }
  .info-block p { color: var(--grigio-700); }
  .info-block a { font-weight: 600; }
  .info-block--dati {
    border-top: 1px solid var(--grigio-100);
    padding-top: 1.5rem;
  }
</style>
