---
import Base from '../../layouts/Base.astro';
import { corsi, LINKEDIN_URL } from '../../data/corsi.js';

export function getStaticPaths() {
  return corsi.map((corso) => ({ params: { slug: corso.slug }, props: { corso } }));
}

const { corso } = Astro.props;
const correlati = corsi.filter((c) => c.area === corso.area && c.cod !== corso.cod);
const fmtPrezzo = (n) => String(n).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
---

<Base
  title={`${corso.cod} · ${corso.titolo} | Mens Sana Formazione`}
  description={corso.sottotitolo}
>
  <!-- HERO SCHEDA -->
  <section class="scheda-hero">
    <div class="container">
      <a href="/formazione/#catalogo" class="back rise" style="--r: 0">← Tutti i corsi</a>
      <div class="scheda-hero__badges rise" style="--r: 1">
        <span class="badge">{corso.cod}</span>
        <span class="scheda-hero__area">{corso.areaNome}</span>
      </div>
      <h1 class="rise" style="--r: 2">{corso.titolo}</h1>
      <p class="scheda-hero__sub rise" style="--r: 3">{corso.sottotitolo}</p>
      <ul class="scheda-hero__meta rise" style="--r: 4">
        <li>🎥 {corso.durataVideo}</li>
        <li>📚 {corso.durataStudio}</li>
        <li>💼 Anche in edizione aziendale su misura</li>
      </ul>
    </div>
  </section>

  <!-- CORPO -->
  <section class="section">
    <div class="container scheda-grid">
      <div class="scheda-main">
        <div class="reveal">
          <p class="eyebrow">Il corso</p>
          {corso.descrizione.map((p) => <p class="scheda-descr">{p}</p>)}
        </div>

        <div class="reveal">
          <p class="eyebrow">Perché iscriversi</p>
          <div class="perche">
            {corso.perche.map((punto, i) => (
              <div class="perche__item spot" style={`--d: ${i * 0.08}s`}>
                <h3>{punto.titolo}</h3>
                <p>{punto.testo}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal">
          <p class="eyebrow">Programma del corso</p>
          <div class="programma">
            {corso.programma.map((sez, i) => (
              <details open={i === 0}>
                <summary>
                  <span class="programma__num">{String(i + 1).padStart(2, '0')}</span>
                  {sez.sezione}
                  <span class="programma__icon">+</span>
                </summary>
                <ul>
                  {sez.voci.map((voce) => <li>{voce}</li>)}
                </ul>
              </details>
            ))}
          </div>
          <p class="nota">
            Il programma può essere modulato su specifici ambiti di interesse, con durata
            diversa su richiesta. {corso.plus}
          </p>
        </div>
      </div>

      <!-- SIDEBAR -->
      <aside class="scheda-side reveal">
        <div class="side-card spot">
          <p class="side-card__label">Quota di iscrizione</p>
          <p class="side-card__prezzo">{fmtPrezzo(corso.prezzo)} € <small>+ IVA</small></p>
          <ul class="side-card__meta">
            <li>{corso.durataVideo}</li>
            <li>{corso.durataStudio}</li>
            <li>Formato: videolezione + studio guidato</li>
          </ul>
          <a href="/contatti/" class="btn btn--primary side-card__cta">Richiedi informazioni</a>
          <a href="/contatti/" class="side-card__link">Ti serve un'edizione aziendale? Parliamone →</a>
        </div>
        <div class="side-card side-card--dest">
          <h3>A chi si rivolge</h3>
          <ul class="dest">
            {corso.destinatari.map((d) => <li>{d}</li>)}
          </ul>
        </div>
        <a href={LINKEDIN_URL} target="_blank" rel="noopener" class="side-linkedin spot spot--dark">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          <span>Pillole di compliance e novità normative:<br /><strong>seguici su LinkedIn</strong></span>
        </a>
      </aside>
    </div>
  </section>

  <!-- CORRELATI -->
  {correlati.length > 0 && (
    <section class="section section--tinted">
      <div class="container">
        <div class="section-head reveal">
          <p class="eyebrow">Nella stessa area</p>
          <h2>Altri corsi di {corso.areaNome}</h2>
        </div>
        <div class="grid grid--3">
          {correlati.map((c, i) => (
            <a href={`/corsi/${c.slug}/`} class="card correlato spot reveal" style={`--d: ${i * 0.08}s`}>
              <span class="badge">{c.cod}</span>
              <h3>{c.titolo}</h3>
              <p class="correlato__prezzo">{fmtPrezzo(c.prezzo)} € <small>+ IVA</small></p>
              <span class="correlato__cta">Vai alla scheda →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="section cta-scheda">
    <div class="container reveal">
      <h2>Vuoi iscriverti o saperne di più?</h2>
      <p>
        Scrivici indicando il corso {corso.cod}: ti rispondiamo entro un giorno lavorativo
        con date, modalità e tutto ciò che serve.
      </p>
      <a href="/contatti/" class="btn btn--primary">Contattaci per il corso {corso.cod}</a>
    </div>
  </section>
</Base>

<style>
  .scheda-hero {
    background:
      radial-gradient(ellipse 55% 60% at 90% 0%, rgba(200, 32, 47, 0.09), transparent),
      var(--carta);
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }
  .back {
    display: inline-block;
    font-weight: 700;
    font-size: var(--fs-300);
    color: var(--grigio-500);
    margin-bottom: 1.4rem;
    transition: color var(--transition);
  }
  .back:hover { color: var(--rosso); }
  .scheda-hero__badges {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1rem;
  }
  .scheda-hero__area {
    font-size: var(--fs-200);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--grigio-500);
  }
  .scheda-hero h1 { max-width: 46rem; font-size: var(--fs-800); }
  .scheda-hero__sub {
    margin-top: 1rem;
    max-width: 42rem;
    font-size: var(--fs-500);
    color: var(--grigio-700);
  }
  .scheda-hero__meta {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.8rem;
    margin-top: 1.6rem;
    font-size: var(--fs-300);
    font-weight: 600;
    color: var(--grigio-700);
  }

  .scheda-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.65fr) minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }
  @media (max-width: 900px) {
    .scheda-grid { grid-template-columns: 1fr; }
  }
  .scheda-main > div { margin-bottom: clamp(2.2rem, 5vw, 3.2rem); }
  .scheda-descr {
    color: var(--grigio-700);
    font-size: var(--fs-500);
    margin-bottom: 1rem;
    max-width: 60ch;
  }

  .perche { display: flex; flex-direction: column; gap: 0.9rem; }
  .perche__item {
    border-left: 3px solid var(--rosso);
    background: var(--carta);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 1.2rem 1.4rem;
  }
  .perche__item h3 { font-size: var(--fs-400); margin-bottom: 0.35rem; }
  .perche__item p { color: var(--grigio-700); font-size: var(--fs-300); }

  .programma { display: flex; flex-direction: column; gap: 0.7rem; }
  .programma details {
    border: 1px solid var(--grigio-100);
    border-radius: var(--radius);
    background: var(--bianco);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: border-color var(--transition);
  }
  .programma details[open] { border-color: var(--rosso); }
  .programma summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.3rem;
    font-weight: 700;
    color: var(--nero);
  }
  .programma summary::-webkit-details-marker { display: none; }
  .programma__num {
    font-weight: 800;
    color: var(--rosso);
    font-size: var(--fs-300);
  }
  .programma__icon {
    margin-left: auto;
    flex-shrink: 0;
    width: 1.6rem;
    height: 1.6rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--rosso-tenue);
    color: var(--rosso);
    font-weight: 800;
    transition: transform var(--transition), background var(--transition), color var(--transition);
  }
  .programma details[open] .programma__icon {
    transform: rotate(45deg);
    background: var(--rosso);
    color: var(--bianco);
  }
  .programma ul {
    list-style: none;
    padding: 0 1.3rem 1.2rem 1.3rem;
    animation: prog-open 0.3s ease;
  }
  .programma li {
    position: relative;
    padding-left: 1.4rem;
    margin-bottom: 0.5rem;
    font-size: var(--fs-300);
    color: var(--grigio-700);
  }
  .programma li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 2px;
    background: var(--rosso);
    opacity: 0.7;
  }
  @keyframes prog-open {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: none; }
  }
  .nota {
    margin-top: 1.2rem;
    font-size: var(--fs-300);
    color: var(--grigio-500);
    font-style: italic;
  }

  .scheda-side {
    position: sticky;
    top: 5.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  @media (max-width: 900px) {
    .scheda-side { position: static; }
  }
  .side-card {
    background: var(--bianco);
    border: 1px solid var(--grigio-100);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 1.6rem;
  }
  .side-card__label {
    font-size: var(--fs-200);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--grigio-500);
  }
  .side-card__prezzo {
    font-size: var(--fs-700);
    font-weight: 800;
    color: var(--nero);
    letter-spacing: -0.02em;
    margin-block: 0.3rem 0.9rem;
  }
  .side-card__prezzo small { font-size: var(--fs-300); color: var(--grigio-500); font-weight: 600; }
  .side-card__meta {
    list-style: none;
    margin-bottom: 1.2rem;
    font-size: var(--fs-300);
    color: var(--grigio-700);
  }
  .side-card__meta li {
    padding-left: 1.4rem;
    position: relative;
    margin-bottom: 0.4rem;
  }
  .side-card__meta li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--rosso);
    font-weight: 800;
  }
  .side-card__cta { width: 100%; }
  .side-card__link {
    display: block;
    margin-top: 0.9rem;
    font-size: var(--fs-300);
    font-weight: 600;
    text-align: center;
  }
  .side-card--dest h3 { font-size: var(--fs-400); margin-bottom: 0.7rem; }
  .dest { list-style: none; }
  .dest li {
    padding-left: 1.4rem;
    position: relative;
    margin-bottom: 0.45rem;
    font-size: var(--fs-300);
    color: var(--grigio-700);
  }
  .dest li::before {
    content: '›';
    position: absolute;
    left: 0.2rem;
    color: var(--rosso);
    font-weight: 800;
  }

  .side-linkedin {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    background: var(--nero);
    color: var(--grigio-300);
    border-radius: var(--radius);
    padding: 1.1rem 1.3rem;
    font-size: var(--fs-300);
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .side-linkedin:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .side-linkedin svg { flex-shrink: 0; color: #6cb2ff; }
  .side-linkedin strong { color: var(--bianco); }

  .correlato { display: flex; flex-direction: column; gap: 0.6rem; color: inherit; }
  .correlato h3 { font-size: var(--fs-400); flex-grow: 1; }
  .correlato__prezzo { font-weight: 800; color: var(--nero); }
  .correlato__prezzo small { font-weight: 600; color: var(--grigio-500); font-size: var(--fs-200); }
  .correlato__cta { font-weight: 700; font-size: var(--fs-300); color: var(--rosso); }

  .cta-scheda { text-align: center; }
  .cta-scheda .container { max-width: 42rem; }
  .cta-scheda p { margin-block: 1rem 2rem; color: var(--grigio-700); font-size: var(--fs-500); }
</style>
