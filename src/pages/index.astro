---
import Base from '../layouts/Base.astro';
import { aree, LINKEDIN_URL } from '../data/corsi.js';

const nCorsi = aree.reduce((n, a) => n + a.corsi.length, 0);
---

<Base
  title="Mens Sana Formazione | Formazione Legal & Compliance e Servizi Digitali | Milano"
  description="Formazione e consulenza Legal & Compliance per enti e imprese, e servizi digitali su misura per le piccole attività. Competenza, concretezza, velocità, risultato."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__blob hero__blob--1" aria-hidden="true"></div>
    <div class="hero__blob hero__blob--2" aria-hidden="true"></div>
    <div class="container hero__inner">
      <p class="eyebrow rise" style="--r: 0">Milano · dal 2017</p>
      <h1 class="rise" style="--r: 1">
        La competenza legale che forma.<br />
        <span class="text-rosso"
          >Il digitale che fa <span class="flip-word" id="flip-word">crescere</span>.</span
        >
      </h1>
      <p class="hero__sub rise" style="--r: 2">
        Mens Sana Formazione affianca enti, imprese e professionisti con corsi e
        consulenza <strong>Legal &amp; Compliance</strong>. E oggi porta la stessa
        concretezza alle piccole attività con <strong>Mens Sana Digital</strong>:
        siti web, menu digitali e presenza online.
      </p>
      <div class="hero__actions rise" style="--r: 3">
        <a href="/formazione/" class="btn btn--primary">Scopri i corsi</a>
        <a href="/digital/" class="btn btn--ghost">Servizi digitali per PMI</a>
      </div>
      <ul class="hero__stats rise" style="--r: 4">
        <li><strong data-count={nCorsi}>0</strong><span>corsi a catalogo</span></li>
        <li><strong data-count="8">0</strong><span>aree tematiche</span></li>
        <li><strong data-count="2">0</strong><span>anime, un metodo</span></li>
      </ul>
    </div>
  </section>

  <!-- MARQUEE AREE -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[0, 1].map(() => (
        <>
          <span class="marquee__item">Diritto Societario</span>
          <span class="marquee__item">Internal Auditing</span>
          <span class="marquee__item">Risk Management</span>
          <span class="marquee__item">Compliance</span>
          <span class="marquee__item">Contrattualistica</span>
          <span class="marquee__item">Credit Management</span>
          <span class="marquee__item">Finance &amp; Fiscale</span>
          <span class="marquee__item">GDPR &amp; Privacy</span>
          <span class="marquee__item">Siti Web</span>
          <span class="marquee__item">Menu Digitali</span>
        </>
      ))}
    </div>
  </div>

  <!-- I DUE RAMI -->
  <section class="section">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Cosa facciamo</p>
        <h2>Due anime, la stessa concretezza</h2>
        <p>
          Scegli il percorso che ti riguarda: la formazione legale d'impresa o
          il salto digitale della tua attività.
        </p>
      </div>
      <div class="grid grid--2">
        <a href="/formazione/" class="ramo card reveal spot">
          <span class="badge">Il cuore storico</span>
          <h3>Formazione &amp; Consulenza Legal / Compliance</h3>
          <p>
            Corsi in videolezione su diritto societario, compliance,
            contrattualistica, credit management e fisco. Consulenza su GDPR,
            contratti e transfer pricing.
          </p>
          <span class="ramo__cta">Esplora il catalogo →</span>
        </a>
        <a href="/digital/" class="ramo ramo--digital card reveal spot spot--dark" style="--d: .12s">
          <span class="badge badge--invert">Novità</span>
          <h3>Mens Sana Digital: servizi per piccole attività</h3>
          <p>
            Siti web vetrina, menu digitali con QR code, presenza online e
            grafica per bar, ristoranti, negozi e piccole imprese. Semplice,
            veloce, senza pensieri.
          </p>
          <span class="ramo__cta">Scopri i pacchetti →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- METODO -->
  <section class="section section--dark">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Il metodo</p>
        <h2>Before / During / After</h2>
        <p>
          Lo stesso approccio in tutto ciò che facciamo: capire prima,
          eseguire bene, restare al tuo fianco dopo.
        </p>
      </div>
      <div class="grid grid--3">
        <div class="metodo reveal" style="--d: 0s">
          <span class="metodo__num">01</span>
          <h3>Before · Ascolto</h3>
          <p>
            Analizziamo il tuo contesto e i tuoi obiettivi: nessuna soluzione
            preconfezionata, solo ciò che serve davvero.
          </p>
        </div>
        <div class="metodo reveal" style="--d: .12s">
          <span class="metodo__num">02</span>
          <h3>During · Esecuzione</h3>
          <p>
            Formazione erogata da professionisti del settore, progetti digitali
            consegnati in tempi rapidi e con standard alti.
          </p>
        </div>
        <div class="metodo reveal" style="--d: .24s">
          <span class="metodo__num">03</span>
          <h3>After · Presenza</h3>
          <p>
            Verifica dei risultati, assistenza continuativa e aggiornamento nel
            tempo. Non consegniamo e spariamo: restiamo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- VALORI -->
  <section class="section section--tinted">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Perché noi</p>
        <h2>Competenza, concretezza, velocità, risultato</h2>
      </div>
      <div class="grid grid--2">
        <div class="card reveal spot">
          <h3>Team giovane, radici solide</h3>
          <p>
            Professionisti con background giuridico e internazionale, abituati a
            parlare la lingua delle imprese, non solo quella dei codici.
          </p>
        </div>
        <div class="card reveal spot" style="--d: .12s">
          <h3>Su misura, sempre</h3>
          <p>
            Ogni corso e ogni progetto digitale parte dalle tue esigenze
            specifiche. Il catalogo è la base, la personalizzazione è la regola.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LINKEDIN -->
  <section class="section">
    <div class="container">
      <a
        href={LINKEDIN_URL}
        target="_blank"
        rel="noopener"
        class="linkedin-banner spot spot--dark reveal"
      >
        <div class="linkedin-banner__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="30" height="30" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
        </div>
        <div class="linkedin-banner__text">
          <h2>Il diritto d'impresa, spiegato bene. Su LinkedIn.</h2>
          <p>
            Pillole di compliance, novità normative e anteprime dei nostri corsi:
            seguici e resta aggiornato dove lavori ogni giorno.
          </p>
        </div>
        <span class="btn btn--light linkedin-banner__cta">Segui Mens Sana Formazione</span>
      </a>
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="section cta-final">
    <div class="container reveal">
      <h2>Parliamo del tuo progetto</h2>
      <p>
        Un corso per il tuo team, una consulenza compliance o il sito della tua
        attività: raccontaci di cosa hai bisogno, ti rispondiamo in fretta.
      </p>
      <a href="/contatti/" class="btn btn--primary">Contattaci ora</a>
    </div>
  </section>
</Base>

<script>
  const words = ['crescere', 'vendere', 'spiccare', 'ripartire'];
  const el = document.getElementById('flip-word');
  if (el && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let i = 0;
    setInterval(() => {
      el.classList.add('is-out');
      setTimeout(() => {
        i = (i + 1) % words.length;
        el.textContent = words[i];
        el.classList.remove('is-out');
      }, 300);
    }, 2600);
  }
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    background: linear-gradient(180deg, var(--carta), var(--bianco));
    padding-block: clamp(4rem, 10vw, 8rem);
  }
  .hero__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.55;
    pointer-events: none;
  }
  .hero__blob--1 {
    width: 34rem;
    height: 34rem;
    right: -10rem;
    top: -12rem;
    background: radial-gradient(circle, rgba(200, 32, 47, 0.28), transparent 65%);
    animation: blob-drift 14s ease-in-out infinite alternate;
  }
  .hero__blob--2 {
    width: 26rem;
    height: 26rem;
    left: -12rem;
    bottom: -14rem;
    background: radial-gradient(circle, rgba(23, 24, 28, 0.16), transparent 65%);
    animation: blob-drift 18s ease-in-out infinite alternate-reverse;
  }
  @keyframes blob-drift {
    from { transform: translate(0, 0) scale(1); }
    to { transform: translate(-3.5rem, 2.5rem) scale(1.15); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__blob { animation: none; }
  }

  .hero__inner { position: relative; max-width: 46rem; }
  .hero__sub {
    margin-top: 1.5rem;
    font-size: var(--fs-500);
    color: var(--grigio-700);
    max-width: 38rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2.2rem;
  }
  .hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1.5rem, 5vw, 3.5rem);
    list-style: none;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--grigio-100);
  }
  .hero__stats li { display: flex; flex-direction: column; }
  .hero__stats strong {
    font-size: var(--fs-700);
    color: var(--nero);
    letter-spacing: -0.02em;
  }
  .hero__stats span { font-size: var(--fs-300); color: var(--grigio-500); }

  .ramo { display: flex; flex-direction: column; gap: 0.8rem; color: inherit; }
  .ramo h3 { font-size: var(--fs-600); }
  .ramo p { color: var(--grigio-700); flex-grow: 1; }
  .ramo__cta { font-weight: 700; color: var(--rosso); }
  .ramo--digital {
    background: var(--nero);
    border-color: var(--nero);
  }
  .ramo--digital h3 { color: var(--bianco); }
  .ramo--digital p { color: var(--grigio-300); }
  .ramo--digital .ramo__cta { color: #ff8a94; }
  .badge--invert { background: rgba(200, 32, 47, 0.25); color: #ff8a94; }

  .metodo {
    border-top: 2px solid var(--grigio-900);
    padding-top: 1.25rem;
  }
  .metodo__num {
    font-size: var(--fs-700);
    font-weight: 800;
    color: var(--rosso);
    letter-spacing: -0.02em;
  }
  .metodo h3 { margin-block: 0.5rem; font-size: var(--fs-500); }
  .metodo p { color: var(--grigio-300); font-size: var(--fs-300); }

  .linkedin-banner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: clamp(1.2rem, 3vw, 2.2rem);
    background: linear-gradient(120deg, #0a66c2, #084d92 55%, var(--nero));
    color: rgba(255, 255, 255, 0.85);
    border-radius: var(--radius-lg);
    padding: clamp(1.6rem, 4vw, 2.6rem) clamp(1.4rem, 4vw, 3rem);
    box-shadow: 0 16px 44px rgba(10, 102, 194, 0.35);
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .linkedin-banner:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 54px rgba(10, 102, 194, 0.45);
  }
  .linkedin-banner__icon {
    display: grid;
    place-items: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
  }
  .linkedin-banner__text h2 {
    color: #fff;
    font-size: var(--fs-600);
    margin-bottom: 0.35rem;
  }
  .linkedin-banner__text p { font-size: var(--fs-300); max-width: 34rem; }
  .linkedin-banner__cta { white-space: nowrap; }
  @media (max-width: 760px) {
    .linkedin-banner { grid-template-columns: 1fr; text-align: left; }
    .linkedin-banner__cta { justify-self: start; }
  }

  .cta-final { text-align: center; }
  .cta-final .container { max-width: 42rem; }
  .cta-final p {
    margin-block: 1rem 2rem;
    color: var(--grigio-700);
    font-size: var(--fs-500);
  }
</style>
