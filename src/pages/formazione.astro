---
import Base from '../layouts/Base.astro';
import { aree, areeSuRichiesta, consulenze } from '../data/corsi.js';

const fmtPrezzo = (n) => String(n).replace(/\B(?=(\d{3})+(?!\d))/g, '.');
---

<Base
  title="Formazione & Consulenza Legal e Compliance | Mens Sana Formazione"
  description="Catalogo corsi in videolezione: diritto societario, compliance, contrattualistica, credit management, finance e fiscale. Consulenza GDPR, contratti e transfer pricing."
>
  <!-- INTRO -->
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Il cuore storico</p>
      <h1>Formazione &amp; Consulenza<br />Legal / Compliance</h1>
      <p class="page-hero__sub">
        Corsi in videolezione con studio guidato, pensati per chi in azienda
        deve decidere, controllare e firmare. E consulenza operativa dove serve
        una mano esperta subito.
      </p>
    </div>
  </section>

  <!-- CATALOGO -->
  <section class="section" id="catalogo">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Catalogo corsi</p>
        <h2>Scegli la tua area</h2>
        <p>
          Tutti i corsi sono erogati in formato videolezione + studio
          individuale. Prezzi IVA esclusa. Possibilità di edizioni aziendali su
          misura.
        </p>
      </div>

      <div class="filtri reveal">
        <button class="chip is-active" data-filter="all">Tutte le aree</button>
        {aree.map((area) => (
          <button class="chip" data-filter={area.sigla}>
            {area.sigla} · {area.nome}
          </button>
        ))}
      </div>

      <div class="grid grid--3 catalogo-grid reveal" id="catalogo-grid">
        {aree.map((area) =>
          area.corsi.map((corso) => (
            <a href={`/corsi/${corso.slug}/`} class="card corso spot" data-area={area.sigla}>
              <div class="corso__top">
                <span class="badge">{corso.cod}</span>
                <span class="corso__area">{area.nome}</span>
              </div>
              <h4>{corso.titolo}</h4>
              <p class="corso__sotto">{corso.sottotitolo}</p>
              <p class="corso__prezzo">
                {fmtPrezzo(corso.prezzo)} € <small>+ IVA</small>
              </p>
              <span class="corso__link">Scopri il corso →</span>
            </a>
          ))
        )}
      </div>

      <div class="su-richiesta reveal">
        <h3>Altre aree su richiesta</h3>
        <p>
          Progettiamo percorsi dedicati anche in queste aree: contattaci per
          un programma su misura:
        </p>
        <ul>
          {areeSuRichiesta.map((a) => (
            <li><strong>{a.sigla}</strong> {a.nome}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- CONSULENZA -->
  <section class="section section--dark" id="consulenza">
    <div class="container">
      <div class="section-head reveal">
        <p class="eyebrow">Consulenza</p>
        <h2>Quando serve chi lo fa di mestiere</h2>
        <p>
          Oltre alla formazione, affianchiamo le imprese direttamente
          sull'operatività legale e di compliance.
        </p>
      </div>
      <div class="grid grid--3">
        {consulenze.map((c) => (
          <div class="consulenza reveal">
            <h3>{c.titolo}</h3>
            <p>{c.testo}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--tinted cta-form">
    <div class="container reveal">
      <h2>Formazione su misura per la tua azienda?</h2>
      <p>
        Raccontaci esigenze, numeri e tempi: costruiamo il percorso giusto e ti
        mandiamo una proposta chiara, senza sorprese.
      </p>
      <a href="/contatti/" class="btn btn--primary">Richiedi una proposta</a>
    </div>
  </section>
</Base>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('.corso[data-area]');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('is-active'));
      chip.classList.add('is-active');
      const f = chip.dataset.filter;
      cards.forEach((card) => {
        const show = f === 'all' || card.dataset.area === f;
        card.classList.remove('pop-in');
        if (show) {
          card.style.display = '';
          void card.offsetWidth; // riavvia l'animazione
          card.classList.add('pop-in');
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .filtri {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 2rem;
  }
  .catalogo-grid { margin-bottom: 2.5rem; }
  .corso__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .corso__area {
    font-size: var(--fs-200);
    font-weight: 600;
    color: var(--grigio-500);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: right;
  }

  .page-hero {
    background:
      radial-gradient(ellipse 55% 60% at 90% 0%, rgba(200, 32, 47, 0.08), transparent),
      var(--carta);
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }
  .page-hero__sub {
    margin-top: 1.25rem;
    max-width: 38rem;
    font-size: var(--fs-500);
    color: var(--grigio-700);
  }

  .corso { display: flex; flex-direction: column; gap: 0.7rem; color: inherit; }
  .corso h4 { font-size: var(--fs-400); }
  .corso__sotto {
    font-size: var(--fs-300);
    color: var(--grigio-500);
    flex-grow: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .corso__prezzo {
    font-size: var(--fs-600);
    font-weight: 800;
    color: var(--nero);
    letter-spacing: -0.01em;
  }
  .corso__prezzo small {
    font-size: var(--fs-200);
    font-weight: 600;
    color: var(--grigio-500);
  }
  .corso__link { font-weight: 700; font-size: var(--fs-300); }

  .su-richiesta {
    margin-top: 1rem;
    padding: 1.75rem;
    border: 1.5px dashed var(--grigio-300);
    border-radius: var(--radius);
    background: var(--carta);
  }
  .su-richiesta h3 { margin-bottom: 0.4rem; }
  .su-richiesta ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.8rem;
    margin-top: 0.8rem;
  }
  .su-richiesta strong { color: var(--rosso); }

  .consulenza {
    border-top: 2px solid var(--rosso);
    padding-top: 1.2rem;
  }
  .consulenza h3 { font-size: var(--fs-500); margin-bottom: 0.5rem; }
  .consulenza p { color: var(--grigio-300); font-size: var(--fs-300); }

  .cta-form { text-align: center; }
  .cta-form .container { max-width: 42rem; }
  .cta-form p { margin-block: 1rem 2rem; color: var(--grigio-700); }
</style>
