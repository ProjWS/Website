---
import '../styles/global.css';
import { LINKEDIN_URL } from '../data/corsi.js';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
const nav = [
  { href: '/', label: 'Home' },
  { href: '/formazione/', label: 'Formazione & Consulenza' },
  { href: '/digital/', label: 'Mens Sana Digital' },
  { href: '/contatti/', label: 'Contatti' },
];
const current = Astro.url.pathname;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/logo.png" />
  </head>
  <body>
    <div class="scroll-progress" id="scroll-progress" aria-hidden="true"></div>
    <header class="site-header" id="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__brand" aria-label="Mens Sana Formazione, home">
          <img src="/logo.png" alt="Mens Sana Formazione" width="170" height="48" />
        </a>
        <nav class="site-nav" id="site-nav" aria-label="Navigazione principale">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={['site-nav__link', { 'is-active': current === item.href }]}
            >
              {item.label}
            </a>
          ))}
          <a
            href={LINKEDIN_URL}
            target="_blank"
            rel="noopener"
            class="site-nav__linkedin"
            aria-label="Seguici su LinkedIn"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
          <a href="/contatti/" class="btn btn--primary site-nav__cta">Parliamone</a>
        </nav>
        <button
          class="nav-toggle"
          id="nav-toggle"
          aria-label="Apri il menu"
          aria-expanded="false"
          aria-controls="site-nav"
        >
          <span></span><span></span><span></span>
        </button>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container site-footer__grid">
        <div>
          <img src="/logo.png" alt="Mens Sana Formazione" width="180" class="site-footer__logo" />
          <p>
            Formazione e consulenza Legal &amp; Compliance per enti, imprese e
            professionisti. E con <strong>Mens Sana Digital</strong>, servizi
            digitali su misura per le piccole attività.
          </p>
        </div>
        <div>
          <h3>Contatti</h3>
          <ul>
            <li>Via San Francesco d'Assisi, 13, 20122 Milano</li>
            <li><a href="tel:+390281558505">(+39) 02 8155 8505</a></li>
            <li><a href="tel:+393519013820">(+39) 351 901 3820</a></li>
            <li><a href="mailto:info@mensanaformazione.com">info@mensanaformazione.com</a></li>
            <li>PEC: info@pec.mensanaformazione.com</li>
          </ul>
          <a href={LINKEDIN_URL} target="_blank" rel="noopener" class="site-footer__linkedin">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0z"/></svg>
            Seguici su LinkedIn
          </a>
        </div>
        <div>
          <h3>Orari</h3>
          <ul>
            <li>Lun-Ven: 9:00-18:00</li>
            <li>Sabato: 9:00-12:00</li>
          </ul>
          <h3>Esplora</h3>
          <ul>
            <li><a href="/formazione/">Formazione &amp; Consulenza</a></li>
            <li><a href="/digital/">Mens Sana Digital</a></li>
            <li><a href="/contatti/">Contatti</a></li>
            <li><a href="/privacy/">Informativa Privacy e Cookie</a></li>
          </ul>
        </div>
      </div>
      <div class="container site-footer__legal">
        <p>© {new Date().getFullYear()} Mens Sana Formazione S.r.l. · P.IVA 10160940960 · Milano · <a href="/privacy/">Privacy &amp; Cookie</a></p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('nav-toggle');
      const navEl = document.getElementById('site-nav');
      toggle?.addEventListener('click', () => {
        const open = navEl?.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', String(!!open));
        toggle.classList.toggle('is-open', !!open);
      });

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

      // Barra di avanzamento + header compatto durante lo scroll
      const bar = document.getElementById('scroll-progress');
      const header = document.getElementById('site-header');
      const onScroll = () => {
        const max = document.documentElement.scrollHeight - window.innerHeight;
        if (bar) bar.style.transform = `scaleX(${max > 0 ? window.scrollY / max : 0})`;
        header?.classList.toggle('is-scrolled', window.scrollY > 40);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Spotlight: il bagliore segue il mouse sulle card .spot
      document.querySelectorAll('.spot').forEach((el) => {
        el.addEventListener('pointermove', (e) => {
          const r = el.getBoundingClientRect();
          (el as HTMLElement).style.setProperty('--mx', `${e.clientX - r.left}px`);
          (el as HTMLElement).style.setProperty('--my', `${e.clientY - r.top}px`);
        });
      });

      // Contatori animati [data-count]
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const counterObs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            counterObs.unobserve(entry.target);
            const el = entry.target as HTMLElement;
            const target = Number(el.dataset.count || '0');
            if (reduceMotion) { el.textContent = String(target); continue; }
            const t0 = performance.now();
            const dur = 1300;
            const tick = (t: number) => {
              const p = Math.min((t - t0) / dur, 1);
              el.textContent = String(Math.round(target * (1 - Math.pow(1 - p, 3))));
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          }
        },
        { threshold: 0.6 }
      );
      document.querySelectorAll('[data-count]').forEach((el) => counterObs.observe(el));
    </script>

    <style>
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--grigio-100);
      }
      .site-header__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-block: 0.8rem;
        transition: padding var(--transition);
      }
      .site-header__brand img {
        height: 44px;
        width: auto;
        transition: height var(--transition);
      }
      .site-header.is-scrolled { box-shadow: var(--shadow-md); }
      .site-header.is-scrolled .site-header__inner { padding-block: 0.45rem; }
      .site-header.is-scrolled .site-header__brand img { height: 36px; }

      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.6rem;
      }
      .site-nav__link {
        font-size: var(--fs-300);
        font-weight: 600;
        color: var(--grigio-700);
        transition: color var(--transition);
        position: relative;
        padding-block: 0.3rem;
      }
      .site-nav__link::after {
        content: '';
        position: absolute;
        left: 0;
        bottom: 0;
        width: 100%;
        height: 2px;
        background: var(--rosso);
        border-radius: 2px;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--transition);
      }
      .site-nav__link:hover { color: var(--nero); }
      .site-nav__link:hover::after,
      .site-nav__link.is-active::after { transform: scaleX(1); }
      .site-nav__link.is-active { color: var(--nero); }

      .site-nav__linkedin {
        display: grid;
        place-items: center;
        width: 2.3rem;
        height: 2.3rem;
        border-radius: 50%;
        color: var(--grigio-700);
        background: var(--grigio-100);
        transition: background var(--transition), color var(--transition), transform var(--transition);
      }
      .site-nav__linkedin:hover {
        background: #0a66c2;
        color: var(--bianco);
        transform: translateY(-2px);
      }

      .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 5px;
        background: none;
        border: 0;
        padding: 0.5rem;
        cursor: pointer;
      }
      .nav-toggle span {
        width: 24px;
        height: 2.5px;
        background: var(--nero);
        border-radius: 2px;
        transition: transform var(--transition), opacity var(--transition);
      }
      .nav-toggle.is-open span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
      .nav-toggle.is-open span:nth-child(2) { opacity: 0; }
      .nav-toggle.is-open span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }

      @media (max-width: 820px) {
        .nav-toggle { display: flex; }
        .site-nav {
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          align-items: stretch;
          gap: 0;
          background: var(--bianco);
          border-bottom: 1px solid var(--grigio-100);
          box-shadow: var(--shadow-md);
          padding: 0.5rem var(--gutter) 1.25rem;
          display: none;
        }
        .site-nav.is-open { display: flex; }
        .site-nav__link { padding-block: 0.9rem; font-size: var(--fs-400); }
        .site-nav__link::after { display: none; }
        .site-nav__cta { margin-top: 0.75rem; }
        .site-nav__linkedin {
          width: auto;
          height: auto;
          border-radius: 999px;
          padding: 0.7rem 1rem;
          justify-self: start;
          margin-top: 0.5rem;
        }
      }

      .site-footer {
        background: var(--nero);
        color: var(--grigio-300);
        padding-block: clamp(3rem, 6vw, 4.5rem) 0;
        font-size: var(--fs-300);
      }
      .site-footer__grid {
        display: grid;
        gap: 2.5rem;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
        padding-bottom: 2.5rem;
      }
      .site-footer__logo {
        height: 40px;
        width: auto;
        margin-bottom: 1rem;
        filter: brightness(0) invert(1);
      }
      .site-footer h3 {
        color: var(--bianco);
        font-size: var(--fs-300);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.8rem;
      }
      .site-footer h3 + ul + h3 { margin-top: 1.5rem; }
      .site-footer ul { list-style: none; }
      .site-footer li { margin-bottom: 0.45rem; }
      .site-footer a { color: var(--grigio-300); transition: color var(--transition); }
      .site-footer a:hover { color: var(--bianco); }
      .site-footer__linkedin {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        font-weight: 700;
        color: var(--bianco) !important;
        background: #0a66c2;
        padding: 0.5rem 1rem;
        border-radius: 999px;
        transition: transform var(--transition), box-shadow var(--transition);
      }
      .site-footer__linkedin:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 18px rgba(10, 102, 194, 0.4);
      }
      .site-footer__legal {
        border-top: 1px solid var(--grigio-900);
        padding-block: 1.25rem;
        color: var(--grigio-500);
        font-size: var(--fs-200);
      }
    </style>
  </body>
</html>
